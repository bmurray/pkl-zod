amends "pkl:Project"

local repo = "github.com/bmurray/pkl-typescript"

package {
  name = "pkl.typescript"
  baseUri = "package://pkg.pkl-lang.org/github.com/bmurray/pkl-typescript/\(name)"
  packageZipUrl = "https://\(repo)/releases/download/\(name)@\(version)/\(name)@\(version).zip"
  version = read("VERSION.txt").text.trim()
  authors {
    "Brian Murray <bmurray@users.noreply.github.com>"
  }
  sourceCodeUrlScheme = "https://\(repo)/tree/v\(version)/pkl-typescript%{path}#L%{line}-L%{endLine}"
  sourceCode = "https://\(repo)"
  description = "Pkl code generators for TypeScript interfaces and Zod validator schemas"
  license = "MIT"
  exclude {
    "tests"
    "tests/**"
  }
}
