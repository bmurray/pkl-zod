/// TypeScript-specific annotations for controlling code generation.
module pkl.typescript.ts

import "internal/utils.pkl"

/// A valid TypeScript identifier.
typealias TsName = String(!utils.keywords.contains(this) && matches(Regex(#"(?u)\p{L}[\p{L}\d]*"#)))

/// Override the generated TypeScript name for the annotated module, class, typealias, or property.
///
/// Example:
///
/// ```
/// @ts.Name { value = "UserProfile" }
/// class User_Profile
/// ```
class Name extends Annotation {
  value: TsName
}

/// Override the generated TypeScript type for the annotated property.
///
/// The value is rendered verbatim in the generated output.
///
/// Example:
///
/// ```
/// @ts.Type { value = "Date" }
/// createdAt: String
/// ```
class Type extends Annotation {
  value: String
}

/// Mark an abstract class as a discriminated union.
///
/// Instead of generating an interface for the abstract class, this generates
/// a union type of all concrete subclasses, discriminated by the given field.
///
/// Example:
///
/// ```
/// @ts.Union { discriminator = "type" }
/// abstract class Base {
///   type: String
/// }
///
/// class A extends Base {
///   type: "A"
///   valueA: String
/// }
/// ```
///
/// Generates:
/// - TypeScript: `export type Base = A | B;`
/// - Zod: `z.discriminatedUnion("type", [ASchema, BSchema])`
class Union extends Annotation {
  discriminator: String
}
