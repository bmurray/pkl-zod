/// Generates Zod validator schemas from Pkl modules.
///
/// Automatically discovers and generates files for all imported modules,
/// preserving directory structure and using cross-file imports.
@ModuleInfo { minPklVersion = "0.31.0" }
module pkl.typescript.zod.ZodGenerator

import "pkl:reflect"

import "../GeneratorSettings.pkl"
import "../internal/gatherer.pkl"
import "../internal/TsMapping.pkl"
import "../internal/utils.pkl"
import "internal/ZodClassGen.pkl"
import "internal/ZodEnumGen.pkl"

/// Settings to control code generation.
codegenSettings: GeneratorSettings

/// The module that should be generated.
moduleToGenerate: Module

typealias EnumMember = reflect.StringLiteralType | reflect.NothingType

/// Check if a type declaration is an enum-like string literal union.
// noinspection TypeMismatch
function isEnumLike(decl: reflect.TypeDeclaration) =
  decl is reflect.TypeAlias
    && let (referent = decl.referent)
      referent is reflect.UnionType
        && referent.members.every((t) -> t is EnumMember)
        && referent.members
          .filter((t) -> t is reflect.StringLiteralType)
          .every((it: reflect.StringLiteralType) -> utils.canBeNormalizedToEnumName(it.value))
        && referent.members
          .filter((t) -> t is reflect.StringLiteralType)
          .map((it: reflect.StringLiteralType) -> utils.normalizeEnumName(it.value))
          .isDistinct

/// Gather enum-like type aliases from declarations.
function gatherEnums(decl: List<reflect.TypeDeclaration>): List<TsMapping> =
  decl
    .filter((it) -> isEnumLike(it))
    .fold(List(), (acc, it) ->
      acc.add(new TsMapping.Enum {
        source = it
        seenMappings = acc
      })
    )

/// Gather classes from declarations.
/// Skips module companion classes that conflict with inner class names.
function gatherClasses(decl: List<reflect.TypeDeclaration>): Mixin<List<TsMapping>> = (acc) ->
  let (
    companionConflicts =
      decl
        .filter((it) -> it is reflect.Class && it.enclosingDeclaration.moduleClass == it)
        .filter((companion) ->
          decl.any((other) ->
            other is reflect.Class
              && other != companion
              && other.enclosingDeclaration.moduleClass != other
              && utils.toTsTypeName(other) == utils.toTsTypeName(companion)
          )
        )
  )
    decl
      .filter((it) -> it is reflect.Class && !companionConflicts.contains(it))
      .fold(acc, (accum, it) ->
        accum.add(new TsMapping.Class {
          source = it
          seenMappings = accum
        })
      )

local inputMirror = reflect.Module(moduleToGenerate)

/// All type mappings across the entire dependency tree.
local allMappings: List<TsMapping> =
  let (clazz = inputMirror.moduleClass)
  let (declarations = gatherer.gatherTypeDeclarations(clazz, List()))
    gatherEnums(declarations) |> gatherClasses(declarations)

/// All unique module URIs that have mappings.
local discoveredModuleUris: List<String> =
  allMappings
    .map((it) -> it.source.enclosingDeclaration.uri)
    .distinct

/// Get the output file path (relative to output root) for a module URI.
local function outputPath(moduleUri: String): String =
  utils.moduleRelativePath(inputMirror.uri, moduleUri) + ".schema.ts"

/// Get mappings local to a specific module URI.
local function mappingsForModule(moduleUri: String): List<TsMapping> =
  allMappings.filter((it) -> it.source.enclosingDeclaration.uri == moduleUri)

/// Get the reflect.Module for a module URI from one of its mappings.
local function moduleForUri(moduleUri: String): reflect.Module =
  mappingsForModule(moduleUri).first.source.enclosingDeclaration

/// Generate import statements for a module's external dependencies.
local function importsForModule(moduleUri: String): String =
  let (localMappings = mappingsForModule(moduleUri))
  let (externalMappings = allMappings.filter((it) -> it.source.enclosingDeclaration.uri != moduleUri))
  let (
    referencedExternal = externalMappings.filter((ext) ->
      localMappings.any((loc) ->
        loc is TsMapping.Class
          && let (clazz = (loc as TsMapping.Class).clazz)
            clazz.properties.values.any((prop) ->
              allMappings.findOrNull((m) -> m.source == ext.source) != null
                && declarationReferencedByType(prop.type, ext.source)
            )
            || (clazz.superclass != null
              && ext is TsMapping.Class
              && (ext as TsMapping.Class).clazz == clazz.superclass)
      )
    )
  )
  let (fromPath = utils.moduleRelativePath(inputMirror.uri, moduleUri))
  let (
    byModule = referencedExternal.groupBy((it) -> it.source.enclosingDeclaration.uri)
  )
    if (byModule.isEmpty)
      ""
    else
      byModule
        .mapValues((extUri, mappings: List<TsMapping>) ->
          let (toPath = utils.moduleRelativePath(inputMirror.uri, extUri))
          let (importPath = utils.relativeImportPath(fromPath, toPath) + ".schema")
          let (names = mappings.flatMap((m) -> List("\(m.name)Schema", m.name)).distinct.sort())
            "import { \(names.join(", ")) } from \"\(importPath)\";"
        )
        .values
        .join("\n")

/// Check if a reflect type references a given type declaration.
local function declarationReferencedByType(type: reflect.Type, decl: reflect.TypeDeclaration): Boolean =
  if (type is reflect.DeclaredType)
    type.referent == decl
      || type.typeArguments.any((t) -> declarationReferencedByType(t, decl))
      || (type.referent is reflect.TypeAlias && declarationReferencedByType(type.referent.referent, decl))
  else if (type is reflect.NullableType)
    declarationReferencedByType(type.member, decl)
  else if (type is reflect.UnionType)
    type.members.any((t) -> declarationReferencedByType(t, decl))
  else
    false

/// Check if a class has the @ts.Union annotation.
local function hasUnionAnnotation(clazz: reflect.Class): Boolean =
  clazz.annotations.any((it) -> it.getClass().toString() == "pkl.typescript.ts#Union")

/// Reorder mappings so @ts.Union classes come after their children.
local function reorderForUnions(localMappings: List<TsMapping>): List<TsMapping> =
  let (nonUnion = localMappings.filter((it) -> !(it is TsMapping.Class && hasUnionAnnotation((it as TsMapping.Class).clazz))))
  let (unions = localMappings.filter((it) -> it is TsMapping.Class && hasUnionAnnotation((it as TsMapping.Class).clazz)))
    nonUnion + unions

/// Generate the file contents for a single module.
local function generateFileForModule(moduleUri: String): String =
  let (mod = moduleForUri(moduleUri))
  let (localMappings = reorderForUnions(mappingsForModule(moduleUri)))
  let (imports = importsForModule(moduleUri))
  let (
    generated = localMappings.map((it) ->
      if (it is TsMapping.Class)
        new ZodClassGen {
          mappings = allMappings
          mapping = it
        }.contents
      else
        new ZodEnumGen {
          mapping = it as TsMapping.Enum
        }.contents
    )
  )
    new Listing {
      utils.renderHeaderComment(mod)
      ""
      "import { z } from \"zod\";"
      when (!imports.isEmpty) {
        ""
        imports
      }
      ""
      for (gen in generated) {
        gen
      }
    }.join("\n")

output {
  files {
    for (moduleUri in discoveredModuleUris) {
      [outputPath(moduleUri)] {
        text = generateFileForModule(moduleUri)
      }
    }
  }
  text = throw("ZodGenerator.pkl only produces multiple-file output. Try running again with the -m flag.")
}
