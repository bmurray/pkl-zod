/// Entry point for Zod schema generation from Pkl modules.
@ModuleInfo { minPklVersion = "0.31.0" }
module pkl.typescript.zod.gen

extends "pkl:Command"

import "pkl:platform"

import "../GeneratorSettings.pkl"
import "ZodGenerator.pkl"

options: Options

hidden const pwd =
  if (platform.current.operatingSystem == "Windows")
    read("env:PWD").replaceAll("\\", "/")
  else
    read("env:PWD")

class Options {
  /// The output directory to write generated sources into. (default: .)
  @Flag { completionCandidates = "paths" }
  `output-path`: String?

  /// Print the names of the files that will be generated, but don't write any files.
  @BooleanFlag
  `dry-run`: Boolean?

  /// The path to a generator settings file. (default: ./generator-settings.pkl if present)
  @Flag {
    convert = (it) -> new Import { uri = it }
    transformAll = (values) ->
      values.firstOrNull
        ?? if (read?("file://\(pwd)/generator-settings.pkl") != null)
          new Import { uri = "./generator-settings.pkl" }
        else
          new GeneratorSettings {}
    completionCandidates = "paths"
  }
  `generator-settings`: GeneratorSettings

  /// The Pkl modules to generate as Zod schemas.
  @Argument {
    convert = (it) -> new Import { uri = it }
    completionCandidates = "paths"
  }
  pklInputModules: Listing<Module>
}

local effectiveGeneratorSettings: GeneratorSettings = (options.`generator-settings`) {
  dryRun = options.`dry-run` ?? super.dryRun
}

local basePath =
  let (bp = effectiveGeneratorSettings.basePath)
    if (bp.isEmpty || bp.endsWith("/")) bp else bp + "/"

local rawOutputFiles: Listing<Pair<String, FileOutput?>> = new {
  for (input in options.pklInputModules) {
    for (path, file in generateFilesForInput.apply(input, effectiveGeneratorSettings)) {
      Pair(path, file)
    }
  }
}

hidden generateFilesForInput: (Module, GeneratorSettings) -> Mapping<String, FileOutput?> = (
  input,
  settings
) ->
  let (
    files =
      new ZodGenerator {
        moduleToGenerate = input
        codegenSettings = settings
      }
        .output
        .files!!
  )
    new Mapping {
      for (path, file in files) {
        when (basePath.isEmpty) {
          ["\(options.`output-path` ?? pwd)/\(path)"] = file
        } else {
          when (path.startsWith(basePath)) {
            ["\(options.`output-path` ?? pwd)/\(path.drop(basePath.length))"] = file
          } else {
            ["\(options.`output-path` ?? pwd)/\(path)"] = null
          }
        }
      }
    }

local outputFiles: Map<String, FileOutput> =
  rawOutputFiles
    .toList()
    .filter((it) ->
      if (it.value != null)
        true
      else
        let (
          msg =
            "Skipping codegen for file \(it.key) because it does not exist in base path \(basePath)"
        )
        let (_ = trace(msg))
          false
    )
    .toMap((it) -> it.key, (it) -> it.value!!)

output {
  when (effectiveGeneratorSettings.dryRun) {
    text =
      "Dry run; printing filenames but not writing files to disk\n" + outputFiles.keys.join("\n")
  } else {
    files = outputFiles.toMapping()
  }
}
