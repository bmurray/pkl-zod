/// Generates Zod object schemas from Pkl classes.
@Unlisted
module pkl.typescript.zod.internal.ZodClassGen

import "pkl:reflect"

import "../../internal/TsMapping.pkl"
import "../../internal/utils.pkl"
import "../../ts.pkl"
import "zodtypegen.pkl"

/// The mapping for this class.
mapping: TsMapping.Class

/// All mappings.
mappings: List<TsMapping>

local clazz: reflect.Class = mapping.clazz

/// Check if this class has the @ts.Union annotation.
local unionAnnotation: Annotation? =
  clazz.annotations.findOrNull((it) -> it.getClass().toString() == "pkl.typescript.ts#Union")

/// Check if the superclass has the @ts.Union annotation.
local superHasUnion: Boolean =
  if (clazz.superclass == null)
    false
  else
    clazz.superclass.annotations.any((it) -> it.getClass().toString() == "pkl.typescript.ts#Union")

/// Get the discriminator field name from the parent's @ts.Union annotation.
local superDiscriminator: String? =
  if (!superHasUnion)
    null
  else
    // noinspection UnresolvedElement
    clazz.superclass.annotations
      .findOrNull((it) -> it.getClass().toString() == "pkl.typescript.ts#Union")
      ?.discriminator

/// The generated Zod schema contents.
contents: String =
  if (unionAnnotation != null)
    renderDiscriminatedUnion()
  else
    renderObjectSchema()

/// Render a standard z.object() schema.
local function renderObjectSchema(): String =
  // If superclass has @ts.Union, include all fields (no .extend())
  let (ownFields = if (superHasUnion) getAllFields(clazz, mappings) else getOwnFields(clazz, mappings))
  let (schemaName = "\(mapping.name)Schema")
  let (
    superMapping: TsMapping.Class? =
      mappings.findOrNull((c) -> c is TsMapping.Class && (c as TsMapping.Class).clazz == clazz.superclass)
        as TsMapping.Class?
  )
  let (
    baseSchema =
      if (superMapping != null && !superHasUnion)
        "\(superMapping.name)Schema.extend({\(renderFields(ownFields))})"
      else
        "z.object({\(renderFields(ownFields))})"
  )
    new Listing {
      when (clazz.docComment != null) {
        utils.renderDocComment(clazz.docComment!!, "")
      }
      "export const \(schemaName) = \(baseSchema);"
      "export type \(mapping.name) = z.infer<typeof \(schemaName)>;"
      ""
    }.join("\n")

/// Render a z.discriminatedUnion() schema for a @ts.Union-annotated abstract class.
local function renderDiscriminatedUnion(): String =
  let (schemaName = "\(mapping.name)Schema")
  // noinspection UnresolvedElement
  let (discriminator: String = unionAnnotation!!.discriminator)
  let (
    childSchemas = mappings
      .filter((m) -> m is TsMapping.Class && (m as TsMapping.Class).clazz.superclass == clazz)
      .map((m) -> "\(m.name)Schema")
  )
    new Listing {
      when (clazz.docComment != null) {
        utils.renderDocComment(clazz.docComment!!, "")
      }
      "export const \(schemaName) = z.discriminatedUnion(\"\(discriminator)\", [\(childSchemas.join(", "))]);"
      "export type \(mapping.name) = z.infer<typeof \(schemaName)>;"
      ""
    }.join("\n")

local function doesNotInherit(clazz: reflect.Class?) =
  clazz.superclass == null
    || clazz.superclass.reflectee == Module
    || clazz.superclass.reflectee == Typed

local function getAllProperties(clazz: reflect.Class?): List<reflect.Property> =
  if (clazz == null)
    List()
  else if (doesNotInherit(clazz))
    clazz.properties.values
  else
    clazz.properties.values + getAllProperties(clazz.superclass!!)

/// Get only the own (non-inherited) fields for a class.
function getOwnFields(clazz: reflect.Class, mappings: List<TsMapping>): Map<String, ZodField> =
  let (superProperties = getAllProperties(clazz.superclass))
    clazz.properties
      .filter((propName, prop: reflect.Property) ->
        let (superProp = superProperties.findOrNull((it) -> it.name == prop.name))
          if (prop.modifiers.contains("hidden"))
            false
          else if (superProp == null)
            true
          else if (prop.type is reflect.UnknownType)
            false
          else
            true
      )
      .mapValues((_, prop: reflect.Property) -> new ZodField {
        name = utils.toTsPropertyName(prop)
        zodType = resolveZodType(prop, clazz, mappings)
      })

/// Get all fields (own + inherited) for a class, used when parent is a @ts.Union.
///
/// When the discriminator field has a value-only override (`= "value"` instead of `: "value"`),
/// Pkl reflection reports `UnknownType`. Since `z.discriminatedUnion` requires `z.literal()` for
/// the discriminator, the child class MUST use a type annotation to narrow the discriminator type.
function getAllFields(clazz: reflect.Class, mappings: List<TsMapping>): Map<String, ZodField> =
  let (
    superFields: Map<String, ZodField> =
      if (doesNotInherit(clazz))
        Map()
      else
        getAllFields(clazz.superclass!!, mappings)
  )
    superFields + clazz.properties
      .filter((_, prop: reflect.Property) ->
        if (prop.modifiers.contains("hidden"))
          false
        else if (prop.type is reflect.UnknownType && prop.name == superDiscriminator)
          // Value-only override on discriminator: `type = "typeA"` instead of `type: "typeA"`
          // Pkl reflection doesn't expose the default value, so we can't generate z.literal().
          throw(
            """
            Discriminated union member `\(clazz.reflectee)` uses a value assignment for the discriminator field `\(prop.name)`.

            Change `\(prop.name) = "..."` to `\(prop.name): "..."` (type annotation) so the code generator can produce a z.literal() type.

            Example:
              class \(clazz.reflectee) extends \(clazz.superclass!!.reflectee) {
                \(prop.name): "expectedValue"
                ...
              }
            """
          )
        else if (prop.type is reflect.UnknownType)
          // Non-discriminator value-only override — skip so inherited type is preserved
          false
        else
          true
      )
      .mapValues((_, prop: reflect.Property) -> new ZodField {
        name = utils.toTsPropertyName(prop)
        zodType = resolveZodType(prop, clazz, mappings)
      })

/// Resolve the Zod type for a property, respecting @ts.Type overrides.
local function resolveZodType(
  prop: reflect.Property,
  enclosing: reflect.Class,
  seenMappings: List<TsMapping>
): String =
  let (
    typeOverride = prop.annotations
      .findOrNull((it) -> it.getClass().toString() == "pkl.typescript.ts#Type")
  )
    // noinspection UnresolvedElement
    if (typeOverride != null && typeOverride.value == "Date")
      // noinspection UnresolvedElement
      let (fmt = typeOverride.format)
      let (
        baseZodType =
          if (fmt == null)
            "z.coerce.date()"
          else if (fmt == "date")
            "z.iso.date()"
          else if (fmt == "datetime")
            "z.iso.datetime()"
          else
            "z.iso.time()"
      )
        if (prop.type is reflect.NullableType)
          "\(baseZodType).nullable().optional()"
        else
          baseZodType
    else
      zodtypegen.generateZodType(prop.type, enclosing, seenMappings)

/// Render object fields as Zod properties.
local function renderFields(fields: Map<String, ZodField>): String =
  if (fields.isEmpty)
    ""
  else
    "\n" + fields.values.map((f) ->
      "  \(f.name): \(f.zodType),"
    ).join("\n") + "\n"

local class ZodField {
  name: String
  zodType: String
}
